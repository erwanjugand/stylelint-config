{
  "compilerOptions": {
    "lib": ["ESNext"],
    "moduleDetection": "force",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,

    "noEmit": true,
    "rootDir": "."
  },
  "include": ["src", "eslint.config.ts", "prettier.config.ts"]
}
